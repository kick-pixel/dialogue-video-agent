# ─── LLM（必填）────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# 可选：切换国产模型（OpenAI 兼容 API）
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# 通义千问示例：
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus

# ─── 视频配置（可选）────────────────────────────────────────────
# VIDEO_RATIO=9:16         # 视频比例: 9:16（默认竖屏）| 16:9（横屏）
# VIDEO_THEME=tech-dark    # 视觉主题: tech-dark（默认）| neon | light
# CHARACTER_BUNNY_IMAGE=characters/bunny.png   # 小白头像路径（相对 remotion public/ 或绝对路径）
# CHARACTER_FOX_IMAGE=characters/fox.png       # 大橘头像路径

# ─── TTS 引擎（可选，默认: edge）───────────────────────────────
# TTS_ENGINE=edge      # 免费，无需 API Key，使用 Microsoft Edge TTS
# TTS_ENGINE=aliyun    # 阿里云千问 TTS（需 DASHSCOPE_API_KEY）

# 阿里云 TTS（当 TTS_ENGINE=aliyun 时必填）
# DASHSCOPE_API_KEY=sk-xxxx
# 可选：覆盖 TTS 模型（默认: qwen3-tts-flash）
# ALIYUN_TTS_MODEL=qwen3-tts-instruct-flash

# ─── Edge TTS 声音配置（可选）──────────────────────────────────
# VOICE_BUNNY=zh-CN-XiaoxiaoNeural  # 小白 - 甜美女声（默认）
# VOICE_FOX=zh-CN-YunxiNeural       # 大橘 - 清晰男声（默认）

# ─── 阿里云 TTS 声音配置（可选）───────────────────────────────
# ALIYUN_VOICE_BUNNY=Cherry    # 芊悦：阳光积极小姐姐（默认）
# ALIYUN_VOICE_FOX=Ethan       # 晨煦：阳光温暖男生（默认）
# 更多音色: Serena(苏瑶/温柔), Mia(乖小妹), Moon(月白/帅气), Elias(墨讲师)
